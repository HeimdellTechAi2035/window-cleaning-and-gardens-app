# Database (Neon Postgres)
# Get both connection strings from your Neon project dashboard:
#   - DATABASE_URL: the POOLED connection string (uses PgBouncer) — used at runtime.
#   - DATABASE_URL_UNPOOLED: the DIRECT connection string — used only for `prisma migrate deploy`.
# If Netlify's own Neon/DB extension provisions NETLIFY_DATABASE_URL /
# NETLIFY_DATABASE_URL_UNPOOLED instead, just add these two vars pointing at
# the same values (Netlify env vars can reference each other via UI or CLI).
DATABASE_URL="postgresql://user:password@localhost:5432/roundflow"
DATABASE_URL_UNPOOLED="postgresql://user:password@localhost:5432/roundflow"

# App — set this to your real deployed URL on Netlify, e.g. https://your-site.netlify.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# NextAuth — generate a secret with: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"
# Optional but recommended in production: matches NEXT_PUBLIC_APP_URL.
AUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GoCardless
GOCARDLESS_ACCESS_TOKEN=""
GOCARDLESS_ENV="sandbox"
GOCARDLESS_WEBHOOK_SECRET=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Twilio
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""
TWILIO_WHATSAPP_FROM=""

# Resend
RESEND_API_KEY=""
RESEND_FROM_EMAIL="notifications@yourdomain.com"

# Mapbox
MAPBOX_ACCESS_TOKEN=""
NEXT_PUBLIC_MAPBOX_TOKEN=""
